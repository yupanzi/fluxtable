{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "jsx": "react-jsx",

    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    "sourceMap": true,
    "incremental": true,

    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",

    "strict": true,
    // noUncheckedIndexedAccess 暂时关闭：开启后索引访问会被收窄为 T | undefined，
    // 需要逐处补齐边界判断，计划后续单独收敛后再启用。strictNullChecks 已启用。
    "noUncheckedIndexedAccess": false,
    "checkJs": false,
    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*"],
  "exclude": ["**/__tests__/**", "**/*.test.ts", "**/*.test.tsx", "dist", "node_modules"]
}
